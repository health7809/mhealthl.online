server {
    listen 443 ssl;
    server_name healthuniverse.hshub.net
    ssl_certificate / etc / letsencrypt / live / healthuniverse.hsub.net.pem;
    ssl_certificate_key / etc / letsencrypt / live / healthuniverse.hshub.net / privkey.pem;

    root /var/www/html;
    index index.html;
}
